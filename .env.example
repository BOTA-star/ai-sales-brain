# APPLICATION
USE_MOCK=false

# DATABASE
DATABASE_URL=postgresql://postgres:your_password@127.0.0.1:5432/ai_sales_brain
DB_CONNECT_TIMEOUT=10

# LLM PROVIDER
# Giá trị hỗ trợ: ollama | openrouter
LLM_PROVIDER=ollama

# OLLAMA LOCAL
OLLAMA_HOST=
OLLAMA_MODEL=
OLLAMA_TIMEOUT=
OLLAMA_TEMPERATURE=
OLLAMA_MAX_TOKENS=

# OPENROUTER
# Chỉ cần điền khi LLM_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_TIMEOUT=

# RAG
RAG_PERSIST_DIR=
RAG_COLLECTION_NAME=
RAG_EMBEDDING_MODEL=
RAG_TOP_K=
RAG_SIMILARITY_THRESHOLD=
RECENT_CONTEXT_LIMIT=

# UI
CHAT_FRAME_HEIGHT=520
HISTORY_BOX_HEIGHT=360

# Agent Memory
AGENTMEMORY_BASE_URL=
AGENTMEMORY_TIMEOUT_SECONDS=